# Copy this file to .env and fill in real values. Never commit .env.

# Gmail sender account
GMAIL_USER=your-gmail-address@gmail.com

# Gmail App Password (16-char, generated in Google Account → Security → App Passwords)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Port the Express server listens on (Hostinger sets this automatically in most plans)
PORT=8787

# CORS allowed origin — only needed when the web app is served from a DIFFERENT origin
# (e.g. local dev where web=localhost:5173 and server=localhost:8787).
# In production the server serves the web app from the same origin, so this is optional.
ALLOWED_ORIGIN=http://localhost:5173

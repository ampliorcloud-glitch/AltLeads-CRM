{
  "manifest_version": 3,
  "name": "AltLeads Data Research",
  "version": "1.0.0",
  "description": "Research team fulfilment queue — view and fill pending contact enrichment requests from AltLeads CRM.",

  "permissions": ["sidePanel", "tabs", "storage"],

  "host_permissions": [
    "https://puvozfhypqbwbmbhrhcr.supabase.co/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "AltLeads Research",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
